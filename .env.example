# ═══════════════════════════════════════════════════════════
# Swasthya Sense — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit the populated .env to version control.
# ═══════════════════════════════════════════════════════════

# ── PostgreSQL Database ────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# URL-encode special chars in password (@ = %40)
DATABASE_URL=postgresql://postgres:postgresql%40123@localhost:5432/vitals_db

# ── Groq AI (LLaMA 3) ─────────────────────────────────────
# Free key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# ── Email Alerts (optional) ────────────────────────────────
# Uses Gmail SMTP. For Gmail, create an App Password:
# Google Account → Security → App Passwords
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password
